{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "express", "multer", "mysql2", "jsonwebtoken", "dotenv", "cors"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
