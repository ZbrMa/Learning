{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "express",
      "cors",
      "dotenv",
      "jsonwebtoken",
      "multer",
      "mysql2"
    ],
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
